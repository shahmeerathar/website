---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoHead from '../components/seo/SeoHead.astro';

const description = 'Photography portfolio capturing moments from around the world.';
---

<BaseLayout>
  <SeoHead
    title="About"
    description={description}
    canonical="/about"
  />

  <main class="about-page">
    <section class="about-section">
      <h1 class="about-title">About</h1>
      <div class="about-content">
        <div class="about-bio">
          <p class="about-text">
            Shahmeer Athar is a photographer passionate about capturing the beauty and 
            diversity of our world. Through travels across continents, this portfolio 
            documents landscapes, cultures, and moments that tell stories about our 
            shared human experience.
          </p>
          <p class="about-text">
            Each photograph in this collection represents a unique location, carefully 
            selected to showcase the natural and cultural richness found across different 
            latitudes and longitudes. From bustling cities to remote landscapes, every 
            image aims to evoke a sense of place and connection.
          </p>
        </div>

        <div class="about-contact">
          <h2 class="contact-title">Contact</h2>
          <ul class="contact-links">
            <li class="contact-item">
              <a href="mailto:hello@shahmeerathar.com" class="contact-link">
                <span class="contact-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M3 8L10.89 13.26C11.6037 13.7488 12.4011 13.7488 13.1148 13.26L21 8M5 19H19C20.1046 19 21 18.1046 21 17V7C21 5.89543 20.1046 5 19 5H5C3.89543 5 3 5.89543 3 7V17C3 18.1046 3.89543 19 5 19Z"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
                <span>Email</span>
              </a>
            </li>
            <li class="contact-item">
              <a href="https://instagram.com/shahmeerathar" class="contact-link" target="_blank" rel="noopener noreferrer">
                <span class="contact-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect
                      x="2"
                      y="2"
                      width="20"
                      height="20"
                      rx="5"
                      stroke="currentColor"
                      stroke-width="2"
                    />
                    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" />
                    <circle cx="18" cy="6" r="1.5" fill="currentColor" />
                  </svg>
                </span>
                <span>Instagram</span>
              </a>
            </li>
            <li class="contact-item">
              <a href="https://twitter.com/shahmeerathar" class="contact-link" target="_blank" rel="noopener noreferrer">
                <span class="contact-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
                <span>Twitter</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4);
  }

  .about-section {
    padding-top: var(--space-4);
  }

  .about-title {
    font-size: var(--fs-800);
    font-weight: 700;
    margin: 0 0 var(--space-8);
    color: var(--color-text-primary);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .about-bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-text {
    font-size: var(--fs-500);
    color: var(--color-text-secondary);
    line-height: var(--lh-body);
    margin: 0;
  }

  .about-contact {
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-subtle);
  }

  .contact-title {
    font-size: var(--fs-600);
    font-weight: 600;
    margin: 0 0 var(--space-4);
    color: var(--color-text-primary);
  }

  .contact-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-item {
    margin: 0;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--easing);
  }

  .contact-link:hover {
    color: var(--color-accent);
  }

  .contact-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: var(--space-1);
    border-radius: var(--radius-focus);
  }

  .contact-icon {
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 767px) {
    .about-page {
      padding: var(--space-6) var(--space-3);
    }

    .about-title {
      font-size: var(--fs-700);
    }

    .about-text {
      font-size: var(--fs-400);
    }

    .about-content {
      gap: var(--space-8);
    }
  }
</style>