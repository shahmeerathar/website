---
import { getMapPins } from '../../lib/data';
import type { MapPinView } from '../../types/content';
import { geoNaturalEarth1, type GeoProjection } from 'd3-geo';

const projection: GeoProjection = geoNaturalEarth1()
  .scale(130)
  .translate([0, 0]);

function getPinPosition(lat: number, lng: number): { x: number; y: number } {
  const point = projection([lng, lat]);
  return { x: point?.[0] ?? 0, y: point?.[1] ?? 0 };
}

const mapPins: MapPinView[] = getMapPins();
const initialSlug = new URL(Astro.request.url).searchParams.get('location') || '';
const initialActiveSlug = mapPins.find((pin) => pin.slug === initialSlug)?.slug || '';
---

<div class="map-pins-layer" data-initial-active={initialActiveSlug}>
  {
    mapPins.map((pin: MapPinView) => {
      const pos = getPinPosition(pin.lat, pin.lng);
      return (
        <button
          class={`map-pin ${pin.slug === initialActiveSlug ? 'map-pin--active' : ''}`}
          data-slug={pin.slug}
          aria-label={`View photos from ${pin.name} (${pin.photoCount} photos)`}
          aria-pressed={pin.slug === initialActiveSlug}
          style={`left: ${pos.x}px; top: ${pos.y}px;`}
        >
          <span class="map-pin__halo"></span>
          <span class="map-pin__pin">
            <span class="map-pin__dot"></span>
          </span>
        </button>
      );
    })
  }
</div>

<style>
  .map-pins-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .map-pin {
    position: absolute;
    width: 24px;
    height: 24px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    transition: transform var(--duration-fast) var(--easing);
    z-index: 10;
    pointer-events: auto;
  }

  .map-pin:hover,
  .map-pin:focus-visible {
    transform: translate(-50%, -50%) scale(1.2);
    z-index: 20;
  }

  .map-pin:focus-visible {
    outline: 2px solid var(--color-pin-focus);
    outline-offset: 2px;
  }

  .map-pin__halo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 28px;
    height: 28px;
    background: var(--color-pin-active);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    filter: blur(4px);
    animation: none;
    pointer-events: none;
  }

  .map-pin--active .map-pin__halo {
    opacity: 0.3;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.3;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.3);
      opacity: 0.1;
    }
  }

  .map-pin__pin {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 12px;
    height: 12px;
    background: var(--color-pin-default);
    border: 2px solid var(--color-bg);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition:
      width var(--duration-fast) var(--easing),
      height var(--duration-fast) var(--easing),
      background-color var(--duration-fast) var(--easing);
  }

  .map-pin--active .map-pin__pin {
    width: 16px;
    height: 16px;
    background: var(--color-pin-active);
  }

  .map-pin:hover .map-pin__pin {
    background: var(--color-pin-focus);
  }

  .map-pin:hover .map-pin--active .map-pin__pin {
    background: var(--color-pin-active);
  }

  .map-pin__dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 5px;
    height: 5px;
    background: var(--color-bg);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition:
      width var(--duration-fast) var(--easing),
      height var(--duration-fast) var(--easing);
  }

  .map-pin--active .map-pin__dot {
    width: 8px;
    height: 8px;
  }

  @media (prefers-reduced-motion: reduce) {
    .map-pin__halo {
      animation: none;
    }
  }
</style>

<script>
  import { syncLocationQuery } from '../../lib/queryState';

  const pinsLayer = document.querySelector('.map-pins-layer') as HTMLElement;
  const initialActive = pinsLayer?.dataset.initialActive || '';

  let activeSlug: string | null = initialActive || null;

  function activatePin(slug: string) {
    const pins = document.querySelectorAll('.map-pin');
    pins.forEach((pin) => {
      const pinSlug = pin.getAttribute('data-slug');
      if (pinSlug === slug) {
        pin.classList.add('map-pin--active');
        pin.setAttribute('aria-pressed', 'true');
      } else {
        pin.classList.remove('map-pin--active');
        pin.setAttribute('aria-pressed', 'false');
      }
    });
    activeSlug = slug;
    syncLocationQuery(slug);
  }

  function deactivatePin() {
    const activePin = document.querySelector('.map-pin--active') as HTMLElement;
    if (activePin) {
      activePin.classList.remove('map-pin--active');
      activePin.setAttribute('aria-pressed', 'false');
      activeSlug = null;
      syncLocationQuery(null);
      activePin.focus();
    }
  }

  function handlePinClick(event: Event) {
    const pin = event.currentTarget as HTMLElement;
    const slug = pin.getAttribute('data-slug');

    if (!slug) return;

    if (activeSlug === slug) {
      deactivatePin();
    } else {
      activatePin(slug);
    }
  }

  function handlePinKeydown(event: Event) {
    const keyboardEvent = event as KeyboardEvent;
    if (keyboardEvent.key === 'Enter' || keyboardEvent.key === ' ') {
      event.preventDefault();
      handlePinClick(event);
    }
  }

  function handleKeyDown(event: KeyboardEvent) {
    if (event.key === 'Escape' && activeSlug) {
      deactivatePin();
    }
  }

  if (pinsLayer) {
    const pins = pinsLayer.querySelectorAll('.map-pin');
    pins.forEach((pin: Element) => {
      pin.addEventListener('click', handlePinClick);
      pin.addEventListener('keydown', handlePinKeydown);
    });

    window.addEventListener('keydown', handleKeyDown);
  }
</script>