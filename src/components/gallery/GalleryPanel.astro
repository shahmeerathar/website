---
const initialSlug = new URL(Astro.request.url).searchParams.get('location') || '';
---

<aside
  id="gallery-panel"
  class="gallery-panel"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  data-initial-slug={initialSlug}
>
  <div class="gallery-panel__header">
    <div class="gallery-panel__info">
      <h2 class="gallery-panel__title" data-field="title"></h2>
      <div class="gallery-panel__meta">
        <span class="gallery-panel__coordinates" data-field="coordinates"></span>
        <span class="gallery-panel__separator">·</span>
        <span class="gallery-panel__count" data-field="count"></span>
      </div>
    </div>
    <button
      type="button"
      class="gallery-panel__close"
      aria-label="Close gallery"
      id="gallery-panel-close"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M6 6L18 18M6 18L18 6"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </button>
  </div>

  <div class="gallery-panel__content">
    <p class="gallery-panel__description" data-field="description"></p>
    <div id="gallery-panel-photos"></div>
  </div>
</aside>

<style>
  .gallery-panel {
    position: fixed;
    background: var(--color-surface);
    border-radius: var(--radius-card) var(--radius-card) 0 0;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    z-index: 100;
    transition: transform var(--duration-medium) var(--easing);
    display: flex;
    flex-direction: column;
    max-width: 100%;
  }

  @media (max-width: 1023px) {
    .gallery-panel {
      bottom: 0;
      left: 0;
      right: 0;
      height: min(72vh, 680px);
      transform: translateY(100%);
    }

    .gallery-panel--open {
      transform: translateY(0);
    }
  }

  @media (min-width: 1024px) {
    .gallery-panel {
      top: 0;
      right: 0;
      bottom: 0;
      width: min(460px, 38vw);
      transform: translateX(100%);
      border-radius: var(--radius-card) 0 0 var(--radius-card);
    }

    .gallery-panel--open {
      transform: translateX(0);
    }
  }

  .gallery-panel__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: var(--space-6) var(--space-6) var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .gallery-panel__info {
    flex: 1;
    min-width: 0;
  }

  .gallery-panel__title {
    margin: 0 0 var(--space-2);
    font-size: var(--fs-500);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .gallery-panel__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-300);
    color: var(--color-text-muted);
  }

  .gallery-panel__separator {
    color: var(--color-border-subtle);
  }

  .gallery-panel__count {
    color: var(--color-text-secondary);
  }

  .gallery-panel__close {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: transparent;
    border: none;
    color: var(--color-text-secondary);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: color var(--duration-fast) var(--easing),
                background-color var(--duration-fast) var(--easing);
  }

  .gallery-panel__close:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface-elevated);
  }

  .gallery-panel__close:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .gallery-panel__content {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-6);
  }

  .gallery-panel__description {
    margin: 0 0 var(--space-6);
    font-size: var(--fs-300);
    color: var(--color-text-secondary);
    line-height: var(--lh-body);
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-panel {
      transition: transform 0.08s var(--easing);
    }
  }
</style>