---
const { title = 'Shahmeer Athar | Landscape & Travel Photography' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Landscape and travel photography portfolio by Shahmeer Athar" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={Astro.site} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/global.css';
  @import '../styles/utilities.css';
</style>